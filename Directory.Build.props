<Project>

  <PropertyGroup>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>11</LangVersion>
    <NoWarn>SA1633</NoWarn>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
  </PropertyGroup>

  <PropertyGroup>
    <DefaultItemExcludes>$(DefaultItemExcludes);**\zbkp\**</DefaultItemExcludes>
  </PropertyGroup>

  <PropertyGroup>
    <Authors>diginsight</Authors>
    <Product>Diginsight</Product>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageLicenseFile>LICENSE.md</PackageLicenseFile>
    <PackageProjectUrl>https://github.com/diginsight/telemetry</PackageProjectUrl>
    <PackageTags>diginsight;telemetry</PackageTags>
    <!-- TODO <PackageIcon> -->
    <!-- TODO <Description> in each csproj -->
    
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>$(MSBuildThisFileDirectory)diginsight.snk</AssemblyOriginatorKeyFile>

  </PropertyGroup>

  <PropertyGroup>
    <DiginsightDiagnosticsVersion>2.*</DiginsightDiagnosticsVersion>
    <OpenTelemetryVersion>1.*</OpenTelemetryVersion>
	  <OpenTelemetryBetaVersion>1.5.*-*</OpenTelemetryBetaVersion>
  </PropertyGroup>

  <PropertyGroup>


    <DefaultItemExcludes>$(DefaultItemExcludes);**\zbkp\**</DefaultItemExcludes>
  </PropertyGroup>

</Project>
