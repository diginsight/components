@page "/"
@inherits Common.Core.Blazor.ComponentBaseCore

<h1>KeyVault Sample</h1>

<div class="content d-flex px-4 flex-column" style="flex:auto">
    @*background-color:lightyellow;*@
    <div class="row d-flex h-100 align-content-center justify-content-center">
        @* style="background-color:lightcoral"
