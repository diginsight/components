                        <h6 class="card-subtitle pt-2 text-white-50">application</h6>
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">Use Azure Key Vault manager to access an Azure Key Vault.</p>
                </div>
                <div class="card-footer bg-transparent"><p class="card-text"><small class="text-white-50">Last updated 3 mins ago</small></p></div>
            </div>
