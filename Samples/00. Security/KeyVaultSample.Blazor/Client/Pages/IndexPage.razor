        <div class="row ml-5 mr-5 row-cols-4 text-white" style="max-width:1000px">
            <div class="card border-dark mb-4 mr-4" @onclick="@(() => { SelectApplication("Key Vault"); })">
                <div class="card-header border-0 py-3 d-flex align-items-center">
                    <img src="01. RoleManager.svg" class="rounded align-self-start mr-1 text-white" style="width:46px;height:46px">
                    <div>
