{
  "AzureKeyVault": {
    "ClientId": "", // Project specific
    "TenantId": "", // Project specific
    "Uri": "", // Environment specific
    "ClientSecret": "" // Key Vault
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "*.IdentityLoggerAdapter": "None",
      "*.ServiceBusCacheCompanion": "None"
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "", // Key Vault
    "IncludeEventId": false
  },
  "OpenTelemetry": {
    "EnableMetrics": true,
    "EnableTraces": true,
    "TracingSamplingRatio": 1,
    "ActivitySources": [
      "Azure.Cosmos.Operation",
      "Azure.Storage.Blobs.BlobBaseClient",
      "Microsoft.AspNetCore",
      "System.Net.Http",
      "SampleWebApi",
      "Diginsight.*"
      //"*"
    ],
    "ExcludedHttpHosts": [
      "login.microsoftonline.com",
      ".documents.azure.com",
      ".applicationinsights.azure.com",
      ".monitor.azure.com",
      ".b2clogin.com"
    ],
    "DurationMetricTags": [
      "widget_template",
      "site_name"
    ]
  },
  "Diginsight": {
    "Activities": {
      "ActivitySources": [
        "Azure.Cosmos.Operation",
        "Azure.Storage.Blobs.BlobBaseClient",
        "Microsoft.AspNetCore",
        "System.Net.Http",
        "SampleWebApi",
        "Diginsight.*"
        //"*"
      ],
      "LogActivities": true,
      "RecordSpanDurations": true
      //"DisablePayloadRendering": true
    },
    "SmartCache": {
      "MaxAge": "00:05",
      //"MaxAge@...": "00:01",
      //"MaxAge@...": "00:10",
      "AbsoluteExpiration": "1.00:00",
      "SlidingExpiration": "04:00",
      "ServiceBus": {
        "ConnectionString": "", // Key Vault
        "TopicName": "smartcache-commonapi"
      }
    }
  },
  "FeatureManagement": {
    "TraceRequestBody": false,
    "TraceResponseBody": false
  },
  "AppSettings": {
    "ConsoleProviderEnabled": false,
    "Log4NetProviderEnabled": true
  },
  "AllowedHosts": "*",
  "IsSwaggerEnabled": true,

  "SwaggerAuthentication": {
    "Authority": "https://login.microsoftonline.com/common/",
    "Scope": "api://7ceef305-d076-4f0c-8d2c-ed7810935a8f/access_as_user",
    "WebAppClientId": "7ceef305-d076-4f0c-8d2c-ed7810935a8f"
  },
