    <Color x:Key="accentColorOpaque" po:Freeze="True" >#FF001B28</Color>

    <Color x:Key="backgroundColor" po:Freeze="True" >#FFF0F0F0</Color>
    <!--<Color x:Key="backgroundColor" po:Freeze="True" >Yellow</Color>-->
    <Color x:Key="backgroundSemiDarkColor" po:Freeze="True" >#FFC4C4C4</Color>
    <Color x:Key="backgroundDarkColor" po:Freeze="True" >#FF222222</Color>


    <SolidColorBrush x:Key="informationBackgroundBrush" Color="#FF2E92FA" po:Freeze="True" />
