    <SolidColorBrush x:Key="errorBackgroundBrush" Color="#FFFF7300" po:Freeze="True" />

    <SolidColorBrush x:Key="accentColorBrush" Color="{StaticResource accentColor}" po:Freeze="True" />
    <SolidColorBrush x:Key="accentColorOpaqueBrush" Color="{StaticResource accentColorOpaque}" po:Freeze="True" />
    <SolidColorBrush x:Key="backgroundColorBrush" Color="{StaticResource backgroundColor}" po:Freeze="True" />

    <SolidColorBrush x:Key="backgroundSemiDarkColorBrush" Color="{StaticResource backgroundSemiDarkColor}" po:Freeze="True" />
    <SolidColorBrush x:Key="backgroundDarkColorBrush" Color="{StaticResource backgroundDarkColor}" po:Freeze="True" />

