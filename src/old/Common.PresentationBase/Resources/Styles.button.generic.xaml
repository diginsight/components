                        <Rectangle Margin="0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="12" Width="12" >
                            <Rectangle.Fill>
                                <VisualBrush Visual="{StaticResource exitCanvas}" Stretch="Uniform" />
                            </Rectangle.Fill>
                        </Rectangle>
