<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:common="clr-namespace:Common"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:wndBase="clr-namespace:System.Windows;assembly=WindowsBase"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" >
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Common.PresentationBase;component/Resources/Images.generic.xaml" />
        <ResourceDictionary Source="/Common.PresentationBase;component/Resources/Colors.generic.xaml" />
        <ResourceDictionary Source="/Common.PresentationBase;component/Resources/Brushes.generic.xaml" />
        <ResourceDictionary Source="/Common.PresentationBase;component/Resources/Canvas.generic.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="MyFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Control}">
                    <Grid Margin="3 2">
                        <Rectangle Name="r1" StrokeThickness="1" Stroke="Black" StrokeDashArray="2 2"/>
                        <Border Name="border" Width="{TemplateBinding ActualWidth}" Height="{TemplateBinding ActualHeight}"  CornerRadius="2" BorderThickness="1" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ShadowStyle">
        <Setter Property="Control.Foreground" Value="LightGray" />
    </Style>

    <Style x:Key="GlyphButtonTemplate" TargetType="Glyphs">
        <Setter Property="Fill" Value="{StaticResource Grey90}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Fill" Value="{StaticResource Blue4}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DeviceMenuButtonTemplate" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Grey140}"></Setter>
        <Setter Property="Padding" Value="0"></Setter>
        <Setter Property="Margin" Value="0"></Setter>
        <Setter Property="Cursor" Value="Hand"></Setter>
        <Setter Property="FocusVisualStyle" Value="{StaticResource MyFocusVisual}" />
        <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListViewItem}}"/>
        <Setter Property="FontFamily" Value="Helvetica Neue eText Pro Light"/>


        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border  Name="border" Background="{TemplateBinding Background}" BorderThickness="1">
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" Name="content" Content="{TemplateBinding Button.Content}">

                        </ContentPresenter>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Grey230}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource Grey230}"/>
                        </Trigger>
                        <Trigger Property="Tag" Value="modify">
                            <Setter Property="FontFamily" Value="Helvetica Neue eText Pro"/>
                            <Setter Property="FontWeight" Value="ExtraBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="SimpleButtonTemplate" TargetType="Button">
        <Setter Property="Foreground" Value="White"></Setter>
        <Setter Property="Padding" Value="0"></Setter>
        <Setter Property="Margin" Value="10,0,0,0"></Setter>
        <Setter Property="Cursor" Value="Hand"></Setter>
        <Setter Property="FocusVisualStyle" Value="{StaticResource MyFocusVisual}" />
        <Setter Property="Background" Value="{StaticResource Grey38}"/>
        <Setter Property="FontFamily" Value="Helvetica Neue eText Pro Light"/>


        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border  Name="border" Background="{TemplateBinding Background}" BorderThickness="1" TextBlock.Foreground="{TemplateBinding Foreground}"  >
                        <ContentPresenter Margin="{TemplateBinding Margin}" 
                                          VerticalAlignment="Center" 
                                          TextBlock.Foreground="{TemplateBinding Foreground}" 
                                          Name="content" 
                                          Content="{TemplateBinding Button.Content}" >

                        </ContentPresenter>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Grey50}"/>
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource Grey20}"/>
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
