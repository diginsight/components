{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AppSettings": {
    "FlushOnWrite": false,
    "ShowNestedFlow": true,
    "TrackExceptionEnabled": true,
    "TrackTraceEnabled": true,
    "TrackEventEnabled": true,

    "Log4NetProvider.FlushOnWrite": false,
    "Log4NetProvider.ShowNestedFlow": true,

    "Log4NetProvider.IsEnabled": false,
    "ApplicationInsightsLoggerProvider.IsEnabled": true,
    "TraceLoggerConsoleProvider.IsEnabled": true,
    "TraceLoggerDebugProvider.IsEnabled": true,
    "DebugLoggerProvider.IsEnabled": true

    // "CategoryFilter": "-resource",
    // "Filter": "-ModbusMap -CommunicationManager",
    //"AppInsightsKey": ""
  },
  "AllowedHosts": "*"
}
